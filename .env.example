# Council local environment template.
# Copy this file to .env and fill only the providers you intend to enable.
# Never commit real credentials.

# Database
DB_USERNAME=council
DB_PASSWORD=council

# Admin boundary for operational endpoints.
# Protects /api/v1/traces/**, /api/v1/providers/**, /api/v1/metrics,
# /actuator/**, /api/v1/evaluate, /api/v1/evaluations/**, and /api/v1/design/**.
COUNCIL_ADMIN_USERNAME=admin
COUNCIL_ADMIN_PASSWORD=change-this-before-running-any-shared-environment

# Research mode. Optional, but required for live current-source evidence packs.
TAVILY_API_KEY=

# Legacy provider slots. Disabled unless enabled in application.yml/config.
NVIDIA_LLAMA_API_KEY=
NVIDIA_DEEPSEEK_API_KEY=
OPENROUTER_NEMOTRON_API_KEY=
OPENROUTER_QWEN_API_KEY=
DEEPSEEK_R1_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
HUGGINGFACE_API_KEY=

# Claude-quality compatibility slot.
# In this project this slot is routed through Blackbox AI, not Anthropic directly.
CLAUDE_API_KEY=

# Blackbox AI provider family.
BLACKBOX_ENABLED=true
BLACKBOX_BASE_URL=https://api.blackbox.ai/chat/completions

# Live preflight is disabled by default to avoid quota use in startup/CI.
BLACKBOX_PREFLIGHT_ENABLED=false
BLACKBOX_PREFLIGHT_TIMEOUT_MS=10000
BLACKBOX_PREFLIGHT_MAX_TOKENS=8

BLACKBOX_GPT55_ENABLED=false
BLACKBOX_GPT55_API_KEY=
BLACKBOX_GPT55_MODEL=blackboxai/openai/gpt-5.5
BLACKBOX_GPT55_TIMEOUT_MS=60000

BLACKBOX_GPT55_PRO_ENABLED=false
BLACKBOX_GPT55_PRO_API_KEY=
BLACKBOX_GPT55_PRO_MODEL=blackboxai/openai/gpt-5.4-pro
BLACKBOX_GPT55_PRO_TIMEOUT_MS=90000

BLACKBOX_CLAUDE_SONNET_ENABLED=false
BLACKBOX_CLAUDE_SONNET_API_KEY=
BLACKBOX_CLAUDE_SONNET_MODEL=blackboxai/anthropic/claude-sonnet-4.6
BLACKBOX_CLAUDE_SONNET_TIMEOUT_MS=60000

BLACKBOX_CLAUDE_OPUS_ENABLED=false
BLACKBOX_CLAUDE_OPUS_API_KEY=
BLACKBOX_CLAUDE_OPUS_MODEL=blackboxai/anthropic/claude-opus-4.8
BLACKBOX_CLAUDE_OPUS_TIMEOUT_MS=90000

BLACKBOX_GEMINI_ENABLED=false
BLACKBOX_GEMINI_API_KEY=
BLACKBOX_GEMINI_MODEL=blackboxai/google/gemini-3.1-flash-lite
BLACKBOX_GEMINI_TIMEOUT_MS=45000

BLACKBOX_GEMINI_PRO_ENABLED=false
BLACKBOX_GEMINI_PRO_API_KEY=
BLACKBOX_GEMINI_PRO_MODEL=blackboxai/google/nano-banana-pro
BLACKBOX_GEMINI_PRO_TIMEOUT_MS=60000

BLACKBOX_NEMOTRON_ENABLED=false
BLACKBOX_NEMOTRON_API_KEY=
BLACKBOX_NEMOTRON_MODEL=blackboxai/nvidia/nemotron-3-ultra
BLACKBOX_NEMOTRON_TIMEOUT_MS=60000

BLACKBOX_DEEPSEEK_ENABLED=false
BLACKBOX_DEEPSEEK_API_KEY=
BLACKBOX_DEEPSEEK_MODEL=blackboxai/deepseek/deepseek-v4-flash
BLACKBOX_DEEPSEEK_TIMEOUT_MS=60000

BLACKBOX_GROK_ENABLED=false
BLACKBOX_GROK_API_KEY=
BLACKBOX_GROK_MODEL=blackboxai/x-ai/grok-4.3
BLACKBOX_GROK_TIMEOUT_MS=60000
