# Council — LLM Orchestration Engine
# Environment Variables Configuration

# ══════════════════════════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════════════════════════
DB_USERNAME=council
DB_PASSWORD=council

# Admin boundary for operational endpoints.
# Required for /api/v1/traces/**, /api/v1/providers/**, /api/v1/metrics, /actuator/**,
# /api/v1/evaluate, /api/v1/evaluations/**, and /api/v1/design/**.
COUNCIL_ADMIN_USERNAME=admin
COUNCIL_ADMIN_PASSWORD=change-this-before-running-any-shared-environment

# ══════════════════════════════════════════════════════════════════
# TIER A — Always-on Runtime Providers (Used by default in draft phase)
# ══════════════════════════════════════════════════════════════════

# DeepSeek (Priority 1)
# Get key at: https://api.deepseek.com
DEEPSEEK_API_KEY=sk-...

# OpenRouter (Priority 2) - Routes to various models
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-...

# Groq (Priority 3) - Fast inference with Llama/Mixtral
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk-...

# Together AI (Priority 4)
# Get key at: https://www.together.ai/settings/api-keys
TOGETHER_API_KEY=...

# Mistral (Priority 5)
# Get key at: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=...

# ══════════════════════════════════════════════════════════════════
# TIER B — Critic & Premium Escalation Providers
# ══════════════════════════════════════════════════════════════════

# Gemini (Priority 10) - Used for critique and escalation
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Kimi/Moonshot (Priority 11) - Alternative critic provider
# Get key at: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=sk-...

# ══════════════════════════════════════════════════════════════════
# TIER C — Experimental Providers (Optional, disabled by default)
# ══════════════════════════════════════════════════════════════════

# HuggingFace (Priority 50)
# Get key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# ══════════════════════════════════════════════════════════════════
# LEGACY — Backward Compatibility
# ══════════════════════════════════════════════════════════════════

# Claude-quality slot via Blackbox AI (Priority 12) - Fallback/escalation only
# This is routed to https://api.blackbox.ai, not Anthropic.
CLAUDE_API_KEY=blackbox-api-key

# Tavily research mode (optional but required for current web evidence packs)
TAVILY_API_KEY=tvly-...

# ══════════════════════════════════════════════════════════════════
# TESTING NOTE
# ══════════════════════════════════════════════════════════════════
# For unit tests: set any non-empty string (tests use application-test.yml)
# For integration tests with actual API calls: use real API keys above
# For docker-compose: export these vars before running `docker-compose up`

